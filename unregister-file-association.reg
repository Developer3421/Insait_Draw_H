Windows Registry Editor Version 5.00

; Видалення асоціації файлів .insd для поточного користувача
; НЕ потребує прав адміністратора

; Видалення розширення .insd
[-HKEY_CURRENT_USER\Software\Classes\.insd]

; Видалення типу файлу
[-HKEY_CURRENT_USER\Software\Classes\InsaitDrawProject]

; Видалення реєстрації додатку
[-HKEY_CURRENT_USER\Software\Classes\Applications\Insait Draw H.exe]
