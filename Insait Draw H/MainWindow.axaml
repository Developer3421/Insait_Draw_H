<Window xmlns="https://github.com/avaloniaui"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        mc:Ignorable="d" d:DesignWidth="1200" d:DesignHeight="800"
        x:Class="Insait_Draw_H.MainWindow"
        Title="Insait Draw H"
        WindowStartupLocation="CenterScreen"
        SystemDecorations="BorderOnly"
        Width="1200"
        Height="800"
        MinWidth="600"
        MinHeight="400"
        CanResize="True"
        UseLayoutRounding="True"
        FontFamily="Segoe UI, Arial, Tahoma"
        Background="#FFF5E6D3">

    <Window.Resources>
        <Color x:Key="AppBgColor">#FFF5E6D3</Color>
        <Color x:Key="AppSurfaceColor">#FFFDF7EF</Color>
        <Color x:Key="AppBorderColor">#FFE8D5B7</Color>
        <Color x:Key="AppTextColor">#FF404040</Color>
        <Color x:Key="AppTextMutedColor">#FF606060</Color>
        <Color x:Key="AccentPurpleColor">#7D2AE8</Color>

        <SolidColorBrush x:Key="AppBgBrush" Color="{StaticResource AppBgColor}" />
        <SolidColorBrush x:Key="AppSurfaceBrush" Color="{StaticResource AppSurfaceColor}" />
        <SolidColorBrush x:Key="AppBorderBrush" Color="{StaticResource AppBorderColor}" />
        <SolidColorBrush x:Key="AppTextBrush" Color="{StaticResource AppTextColor}" />
        <SolidColorBrush x:Key="AppTextMutedBrush" Color="{StaticResource AppTextMutedColor}" />
        <SolidColorBrush x:Key="AccentPurpleBrush" Color="{StaticResource AccentPurpleColor}" />

        <LinearGradientBrush x:Key="GrayGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFE0E0E0" Offset="0"/>
            <GradientStop Color="#FFD0D0D0" Offset="0.3"/>
            <GradientStop Color="#FFC5C5C5" Offset="0.7"/>
            <GradientStop Color="#FFC0C0C0" Offset="1"/>
        </LinearGradientBrush>
        
        <LinearGradientBrush x:Key="OrangePurpleGradient" StartPoint="0,0" EndPoint="1,1">
            <GradientStop Color="#FFFF9500" Offset="0"/>
            <GradientStop Color="#FFFF6B35" Offset="0.35"/>
            <GradientStop Color="#FFD946EF" Offset="0.65"/>
            <GradientStop Color="#FF9B59B6" Offset="1"/>
        </LinearGradientBrush>
    </Window.Resources>

    <Window.Styles>
        <Style Selector="Button.window-control">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="Foreground" Value="#303030"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="48"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="FontSize" Value="12"/>
            <Setter Property="FontFamily" Value="Segoe UI"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
        </Style>
        <Style Selector="Button.window-control:pointerover">
            <Setter Property="Background" Value="#40FFFFFF"/>
        </Style>
        <Style Selector="Button.window-control.close:pointerover">
            <Setter Property="Background" Value="#40FF5C5C"/>
        </Style>
        <Style Selector="Button.accent-button">
            <Setter Property="Background" Value="Transparent"/>
            <Setter Property="BorderThickness" Value="0"/>
            <Setter Property="Width" Value="38"/>
            <Setter Property="Height" Value="38"/>
            <Setter Property="Cursor" Value="Hand"/>
            <Setter Property="VerticalContentAlignment" Value="Center"/>
            <Setter Property="HorizontalContentAlignment" Value="Center"/>
            <Setter Property="Padding" Value="4"/>
        </Style>
        <Style Selector="Button.accent-button:pointerover">
            <Setter Property="Background" Value="#30FF9500"/>
        </Style>
    </Window.Styles>

    <Grid RowDefinitions="42,*" Background="{StaticResource AppBgBrush}">
        <Grid Grid.Row="0" Name="TitleBar" Background="{StaticResource GrayGradient}" PointerPressed="TitleBar_OnPointerPressed">
            <Grid ColumnDefinitions="Auto,*,Auto" Margin="8,0">
                <StackPanel Grid.Column="0" Orientation="Horizontal" VerticalAlignment="Center" Spacing="8">
                    <Border Width="24" Height="24" Background="{StaticResource AccentPurpleBrush}" CornerRadius="4"/>
                    <TextBlock Text="Insait Draw H" FontSize="14" FontWeight="SemiBold"
                               Foreground="{StaticResource AppTextBrush}" VerticalAlignment="Center"/>
                </StackPanel>

                <Panel Grid.Column="1" Background="Transparent" />

                <StackPanel Grid.Column="2" Orientation="Horizontal" VerticalAlignment="Center" Spacing="4">
                    <!-- Language Button -->
                    <Button Name="LanguageButton" Classes="accent-button" Click="LanguageButton_OnClick" ToolTip.Tip="Language">
                        <Border Width="28" Height="28" CornerRadius="6" Background="{StaticResource OrangePurpleGradient}">
                            <Viewbox Width="18" Height="18">
                                <Canvas Width="24" Height="24">
                                    <!-- Globe icon -->
                                    <Path Fill="White" Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm-1 17.93c-3.95-.49-7-3.85-7-7.93 0-.62.08-1.21.21-1.79L9 15v1c0 1.1.9 2 2 2v1.93zm6.9-2.54c-.26-.81-1-1.39-1.9-1.39h-1v-3c0-.55-.45-1-1-1H8v-2h2c.55 0 1-.45 1-1V7h2c1.1 0 2-.9 2-2v-.41c2.93 1.19 5 4.06 5 7.41 0 2.08-.8 3.97-2.1 5.39z"/>
                                </Canvas>
                            </Viewbox>
                        </Border>
                    </Button>
                    
                    <!-- Accent buttons -->
                    <Button Name="UserAgreementButton" Classes="accent-button" Click="UserAgreementButton_OnClick" ToolTip.Tip="User Agreement">
                        <Border Width="28" Height="28" CornerRadius="6" Background="{StaticResource OrangePurpleGradient}">
                            <Viewbox Width="18" Height="18">
                                <Canvas Width="24" Height="24">
                                    <!-- Shield with checkmark -->
                                    <Path Fill="White" Data="M12 1L3 5v6c0 5.55 3.84 10.74 9 12 5.16-1.26 9-6.45 9-12V5l-9-4zm-2 16l-4-4 1.41-1.41L10 14.17l6.59-6.59L18 9l-8 8z"/>
                                </Canvas>
                            </Viewbox>
                        </Border>
                    </Button>
                    <Button Name="AboutButton" Classes="accent-button" Click="AboutButton_OnClick" ToolTip.Tip="About">
                        <Border Width="28" Height="28" CornerRadius="14" Background="{StaticResource OrangePurpleGradient}">
                            <Viewbox Width="18" Height="18">
                                <Canvas Width="24" Height="24">
                                    <!-- Info icon -->
                                    <Path Fill="White" Data="M12 2C6.48 2 2 6.48 2 12s4.48 10 10 10 10-4.48 10-10S17.52 2 12 2zm1 15h-2v-6h2v6zm0-8h-2V7h2v2z"/>
                                </Canvas>
                            </Viewbox>
                        </Border>
                    </Button>

                    <Border Width="1" Height="24" Background="#40606060" Margin="8,0"/>

                    <!-- Window control buttons -->
                    <Button Name="MinimizeButton" Classes="window-control" Click="MinimizeButton_OnClick">
                        <Image Source="avares://Insait%20Draw%20H/Icons/MinButton.png" Width="32" Height="32"/>
                    </Button>
                    <Button Name="MaximizeButton" Classes="window-control" Click="MaximizeButton_OnClick">
                        <Image Source="avares://Insait%20Draw%20H/Icons/MaxButton.png" Width="32" Height="32"/>
                    </Button>
                    <Button Name="CloseButton" Classes="window-control close" Click="CloseButton_OnClick">
                        <Image Source="avares://Insait%20Draw%20H/Icons/CloseButton.png" Width="32" Height="32"/>
                    </Button>
                </StackPanel>
            </Grid>
        </Grid>

        <Border Grid.Row="1" Margin="8" Background="{StaticResource AppSurfaceBrush}"
                BorderBrush="{StaticResource AppBorderBrush}" BorderThickness="1" CornerRadius="12">
            <ContentControl Name="WebViewHost" />
        </Border>
    </Grid>
</Window>
